{
  "name": "obs-shindan-chan",
  "version": "1.1.4",
  "productName": "OBS診断ちゃん",

  "build": {
    "appId": "com.allegromoltov.obsdiagnose",
    "productName": "OBS診断ちゃん",
    "directories": {
      "output": "dist-release",
      "buildResources": "build"
    },
    "files": [
      "dist",
      "dist-electron",
      "build/icon.ico"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis",
      "artifactName": "OBS診断ちゃん_${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },

  "main": "dist-electron/main/index.js",
  "description": "OBS の配信設定を診断するツールです",
  "author": "AllegroMoltoV <v.molto.allegro@gmail.com>",
  "license": "MIT",
  "private": true,
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:7777/"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "pretest": "vite build --mode=test",
    "test": "vitest run"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "ini": "^5.0.0",
    "wait-on": "^8.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/ini": "^4.1.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/wait-on": "^5.3.4",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^37.4.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.49",
    "postcss-import": "^16.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.4.2",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.5"
  }
}
